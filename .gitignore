# =============================================================================
# Matanuska monorepo — root .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ---------------------------------------------------------------------------
# Build outputs
# ---------------------------------------------------------------------------
dist/
dist-ssr/
build/
out/

# Next.js
.next/

# PWA generated files
dev-dist/
.dev-dist/
**/public/sw.js
**/public/sw.js.map
**/public/workbox-*.js
**/public/workbox-*.js.map

# TypeScript build info
*.tsbuildinfo

# ---------------------------------------------------------------------------
# Environment files
# ---------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
*.local

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---------------------------------------------------------------------------
# Testing / Coverage
# ---------------------------------------------------------------------------
coverage/
.nyc_output/

# ---------------------------------------------------------------------------
# Editor / IDE
# ---------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# OS files
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Deployment / CI caches
# ---------------------------------------------------------------------------
.vercel/
.netlify/
.turbo/

# ---------------------------------------------------------------------------
# Temp / misc
# ---------------------------------------------------------------------------
tmp/
temp/
docs/archive/
archive/
.vercel
